# dogma MCP server environment variables
# Copy this file to .env and fill in values as needed.
# The MCP server itself reads these on startup.

# Port for HTTP/SSE transport (not used in default stdio mode)
DOGMA_MCP_PORT=8000

# Optional bearer token for HTTP transport authentication
# Leave empty to disable token auth (stdio mode is not affected)
DOGMA_MCP_AUTH_TOKEN=
